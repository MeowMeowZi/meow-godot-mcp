[configuration]
entry_symbol = "mcp_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]
linux.debug.x86_64 = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.linux.template_debug.x86_64.so"
windows.debug.x86_64 = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.windows.template_debug.x86_64.dll"
macos.debug = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.macos.template_debug.framework"
linux.release.x86_64 = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.linux.template_release.x86_64.so"
windows.release.x86_64 = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.windows.template_release.x86_64.dll"
macos.release = "res://addons/meow_godot_mcp/bin/libmeow_godot_mcp.macos.template_release.framework"
